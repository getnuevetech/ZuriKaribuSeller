// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── NextAuth Models ──────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(SELLER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  seller   Seller?
  adminProfile AdminProfile?
  passwordResetTokens PasswordResetToken[]
  passwordResetAuditsTriggered PasswordResetAudit[] @relation("PasswordResetAuditActor")
  passwordResetAuditsReceived PasswordResetAudit[] @relation("PasswordResetAuditTarget")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Seller Profile ───────────────────────────────────────────────────────────

model Seller {
  id              String       @id @default(cuid())
  userId          String       @unique
  sellerType      SellerType
  name            String
  mobileNo        String
  businessName    String
  businessLicense String?
  businessAddress String
  country         String
  countryCode     String
  availableFabrics String[]
  designFabrics   String[]
  sendSamples     Boolean      @default(false)
  status          SellerStatus @default(PENDING)
  // Payment methods
  paypalEmail        String?
  wireTransferInfo   Json?
  localDepositInfo   Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  products Product[]

  @@map("sellers")
}

model AdminProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  title        String?
  phoneNumber  String?
  isSuperAdmin Boolean  @default(false)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admin_profiles")
}

// ─── Product ──────────────────────────────────────────────────────────────────

model Product {
  id                 String        @id @default(cuid())
  sellerId           String
  name               String
  description        String        @db.Text
  fabricsUsed        String[]
  costPrice          Float
  sellingPrice       Float
  platformPrice      Float
  status             ProductStatus @default(DRAFT)
  aiOptimized        Boolean       @default(false)
  aiDescription      String?       @db.Text
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  seller          Seller           @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  images          ProductImage[]
  platformProducts PlatformProduct[]

  @@map("products")
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  s3Key     String
  isPrimary Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

// ─── Platform Gateway ─────────────────────────────────────────────────────────

model PlatformGateway {
  id          String   @id @default(cuid())
  platform    Platform @unique
  enabled     Boolean  @default(false)
  credentials Json     // Stored as JSON - API keys, tokens, etc.
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  platformProducts PlatformProduct[]

  @@map("platform_gateways")
}

model PlatformProduct {
  id                String          @id @default(cuid())
  productId         String
  platformGatewayId String
  externalId        String?         // Platform's own product ID
  status            PushStatus      @default(PENDING)
  lastPushedAt      DateTime?
  errorMessage      String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  product         Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  platformGateway PlatformGateway @relation(fields: [platformGatewayId], references: [id])

  @@unique([productId, platformGatewayId])
  @@map("platform_products")
}

// ─── App Settings ─────────────────────────────────────────────────────────────

model AppSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String   @db.Text
  label       String
  description String?
  type        SettingType @default(TEXT)
  category    String   @default("general")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("app_settings")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model PasswordResetAudit {
  id           String           @id @default(cuid())
  actorUserId  String?
  targetUserId String
  action       PasswordResetAction
  metadata     Json?
  createdAt    DateTime         @default(now())

  actorUser  User? @relation("PasswordResetAuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  targetUser User  @relation("PasswordResetAuditTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@index([targetUserId])
  @@index([actorUserId])
  @@map("password_reset_audits")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  SELLER
  ADMIN
}

enum SellerType {
  FASHION_DESIGNER
  FABRIC_SELLER
}

enum SellerStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum ProductStatus {
  DRAFT
  ACTIVE
  INACTIVE
  DELETED
}

enum Platform {
  INSTAGRAM
  TIKTOK
  FACEBOOK
  EBAY
}

enum PushStatus {
  PENDING
  PUSHED
  FAILED
  UPDATED
  REMOVED
}

enum SettingType {
  TEXT
  NUMBER
  BOOLEAN
  JSON
  SELECT
}

enum PasswordResetAction {
  REQUESTED
  COMPLETED
  ADMIN_RESET
}
