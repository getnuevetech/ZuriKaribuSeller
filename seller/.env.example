# Local PostgreSQL (matches docker-compose.yml)
# user / password / database are all: zurikaribu
DATABASE_URL=postgresql://zurikaribu:zurikaribu@localhost:5432/zurikaribu?schema=public

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-to-a-random-secret
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (optional for local email/password login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AWS S3 (optional for local; uploads fail without these)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# OpenAI (optional for local; AI features fail without this)
OPENAI_API_KEY=

# Database
DATABASE_URL=******localhost:5432/zurikaribu?schema=public
