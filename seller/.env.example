# Local PostgreSQL (matches docker-compose.yml)
# user / password / database are all: zurikaribu
DATABASE_URL=postgresql://zurikaribu:zurikaribu@localhost:5432/zurikaribu?schema=public

# Admin seed credentials — used by `npm run seed` to create initial admin accounts.
# Set these before running the seed in production and change the passwords after first login.
ADMIN_EMAIL=admin@zurikaribu.com
ADMIN_PASSWORD=Admin@ZuriKaribu2024!
# Optional secondary admin account (e.g. a platform operator). Leave blank to use the default (ag@nuevetech.io).
# If SECONDARY_ADMIN_PASSWORD is set (non-empty), the password is updated on every seed run — useful for resets.
SECONDARY_ADMIN_EMAIL=ag@nuevetech.io
SECONDARY_ADMIN_PASSWORD=Admin@NueveTech2024!

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-to-a-random-secret
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (optional for local email/password login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AWS S3 (optional for local; uploads fail without these)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# OpenAI (optional for local; AI features fail without this)
OPENAI_API_KEY=

# Set to "true" to show the Google Sign-In button in the UI (requires GOOGLE_CLIENT_ID/SECRET above)
NEXT_PUBLIC_GOOGLE_ENABLED=

# Seller notification webhook (optional). If empty, notifications are logged to server console.
NOTIFICATION_EMAIL_WEBHOOK_URL=
NOTIFICATION_EMAIL_WEBHOOK_TOKEN=
SUPPORT_EMAIL=support@zurikaribu.com
